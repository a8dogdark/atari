   372 												$20	,	Spc	.	N	 	M	/	Inv	R	 	E	Y	Tab	T	W	Q
   373 												$30	9	 	0	7	BS	8	<	>	F	H	D	 	Cap	G	S	A
   374
   375 												together with Shift Key: add +$40
   376 												together with Control key: add +$80 
   377 												*/
