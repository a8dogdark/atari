   292 												;--------------------------------------------------------------------------------
   293 												; SetBasic [0,1]
   294 												;--------------------------------------------------------------------------------
   295
   296 													.macro SetBasic
   297 													   .if :0 <> 1
   298 													      .error "SetBasic error"
   299 												
   300 													   .else
   301 													      .if :1 = 0
   302 													         lda PORTB	; deactivate Basic
   303 													         ora #%00000010
   304 													         sta PORTB
   305 													      .else
   306 													         lda PORTB	; activate Basic
   307 													         and #%11111101
   308 													         sta PORTB
   309 													      .endif
   310 													   .endif
   311 												
   312 													.endm
