   290 												; Convert an 16 bit binary value into a 24bit BCD value
   291 2658												BIN2BCD
   292 2658 20 37 26											JSR LIMPIORES
   293 265B A9 00												LDA #0		  ;Clear the result area
   294 265D 8D 30 26											STA RESBCD+0
   295 2660 8D 31 26											STA RESBCD+1
   296 2663 8D 32 26											STA RESBCD+2
   297 2666 8D 33 26											STA RESBCD+3
   298 2669 A2 18												LDX #24		 ;Setup the bit counter
   299 266B F8												SED			 ;Enter decimal mode
   300 266C												LOOPHEX
   301 266C 0E 34 26											ASL VAL+0	   ;Shift a bit out of the binary
   302 266F 2E 35 26											ROL VAL+1
   303 2672 2E 36 26											ROL VAL+2	   ;... value
   304 2675 AD 30 26											LDA RESBCD+0	   ;And add it into the result, doubling
   305 2678 6D 30 26											ADC RESBCD+0	   ;... it at the same time
   306 267B 8D 30 26											STA RESBCD+0
   307 267E AD 31 26											LDA RESBCD+1
   308 2681 6D 31 26											ADC RESBCD+1
   309 2684 8D 31 26											STA RESBCD+1
   310 2687 AD 32 26											LDA RESBCD+2
   311 268A 6D 32 26											ADC RESBCD+2
   312 268D 8D 32 26											STA RESBCD+2
   313 2690 AD 33 26											LDA RESBCD+3
   314 2693 6D 33 26											ADC RESBCD+3
   315 2696 8D 33 26											STA RESBCD+3
   316 2699 CA												DEX			 ;More bits to process?
   317 269A D0 D0												BNE LOOPHEX
   318 269C D8												CLD			 ;Leave decimal mode
