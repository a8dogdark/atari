   126 												;Deteccion de memoria adicional
   127 												;El programa verifica la 
   128 												;presencia de una extension
   129 												;de memoria basandose en los 
   130 												;codigos de banco dBANK 
   131 												;permitidos y guarda los bancos
   132 												;encontrados desde la direccion
   133 												;TABMEMBANKS+1.
   134 												;El metodo de prueba excluye la 
   135 												;posibilidad de duplicar 
   136 												;cualquier banco de memoria
   137 												;adicional.
   138 												;La primera entrada en la tabla
   139 												;TABMEMBANKS es el valor 
   140 												;$FF, este es el codigo del
   141 												;banco numero 0 en la memoria
   142 												;primaria.
   143 												;La tabla con los bancos de
   144 												;memoria encontrados puede
   145 												;contener como maximo 65
   146 												;entradas.
   147 												;(para 1 MB de memoria 
   148 												;adicional).
   149 												;El numero de bancos 
   150 												;encontrados se devuelve en
   151 												;el registro del acumulador
   152 												;A.
   153 												;numero maximo de bancos de
   154 												;memoria
   155 = 0040											MAXBANKS = 64		
   156 2554												MEMORIA
   157 2554 00 00 00										    .BY $00,$00,$00
   158 2557												MEM
   159 2557 A9 00											    LDA #$00
   160 2559 8D 54 25										    STA MEMORIA
   161 255C 8D 55 25										    STA MEMORIA+1
   162 255F 8D 56 25										    STA MEMORIA+2
   163 												;byte de la memoria primaria
   164 2562 AD FF 7F											LDA $7FFF	
   165 2565 8D E7 25											STA TEMP
   166 2568 A2 3F											    LDX #MAXBANKS-1
   167 256A												S1 
   168 256A BD E8 25										    LDA DBANK,X
   169 256D 8D 01 D3										    STA PORTB
   170 2570 AD FF 7F										    LDA $7FFF
   171 2573 9D 00 06										    STA TABMEMBANKS,X
   172 2576 CA											    DEX
   173 2577 10 F1											    BPL S1
   174 2579 A2 3F											    LDX #MAXBANKS-1
   175 257B												S2 
   176 257B BD E8 25										    LDA DBANK,X
   177 257E 8D 01 D3										    STA PORTB
   178 2581 8D FF 7F										    STA $7FFF
   179 2584 CA											    DEX
   180 2585 10 F4											    BPL S2
   181 												;volvemos a la memoria basica,
   182 												;aqui debajo de $7FFF
   183 												;escribimos el valor $FF
   184 2587 A9 FF												LDA #$FF
   185 2589 8D 01 D3											STA PORTB
   186 258C 8D FF 7F											STA $7FFF
   187 258F 8D 00 06											STA TABMEMBANKS ; primera
   188 												;entrada en TABMEMBANKS = $FF
   189 												;comprobamos la presencia de
   190 												;bancos de memoria adicionales,
   191 												;guardamos los bancos detectados
   192 												;desde la direccion 
   193 												;TABMEMBANKS+1 el registro
   194 												;Y cuenta los bancos de memoria
   195 												;encontrados
   196 2592 A0 00												LDY #0
   197 2594 A2 3F											    LDX #MAXBANKS-1
   198 2596												LOP	
   199 2596 BD E8 25										    LDA DBANK,X
   200 2599 8D 01 D3										    STA PORTB
   201 259C CD FF 7F										    CMP $7FFF
   202 259F D0 07											    BNE SKP
   203 25A1 99 01 06											STA TABMEMBANKS+1,Y
   204 25A4 C8											    INY
   205 25A5 8C 4D 25										    STY BANKOS
   206 25A8												SKP
   207 25A8 CA											    DEX
   208 25A9 10 EB											    BPL LOP
   209 25AB A2 3F											    LDX #MAXBANKS-1
   210 25AD												R3 
   211 25AD BD E8 25										    LDA DBANK,X
   212 25B0 8D 01 D3										    STA PORTB
   213 25B3 BD 00 06										    LDA TABMEMBANKS,X
   214 25B6 8D FF 7F										    STA $7FFF
   215 25B9 CA											    DEX
   216 25BA 10 F1											    BPL R3
   217 												;Terminamos restaurando la 
   218 												;memoria primaria.
   219 25BC A9 FF											    LDA #$FF
   220 25BE 8D 01 D3										    STA PORTB
   221 												;Restauramos el contenido 
   222 25C1 A9 00												LDA #0		
   223 												;antiguo de la celda de memoria
   224 												;desde la direccion $7FFF en la
   225 												;memoria primaria.
   226 25C3 8D FF 7F											STA $7FFF
   227 												;en regla el numero de bancos 
   228 												;de memoria adicionales
   229 												;encontrados
   230 25C6 98												TYA		
   231 25C7 AE 4D 25										    LDX BANKOS
   232 25CA CA											    DEX
   233 25CB												CALMEM
   234 25CB AD 54 25										    LDA MEMORIA
   235 25CE 69 00												ADC #$00
   236 25D0 8D 54 25											STA MEMORIA
   237 25D3 AD 55 25											LDA MEMORIA+1
   238 25D6 69 40												ADC #$40
   239 25D8 8D 55 25											STA MEMORIA+1
   240 25DB AD 56 25											LDA MEMORIA+2
   241 25DE 69 00												ADC #$00
   242 25E0 8D 56 25											STA MEMORIA+2
   243 25E3 CA												DEX
   244 25E4 10 E5											    BPL CALMEM
   245 25E6 60											    RTS
