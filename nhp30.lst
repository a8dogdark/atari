   124 												;Deteccion de memoria adicional
   125 												;El programa verifica la 
   126 												;presencia de una extension
   127 												;de memoria basandose en los 
   128 												;codigos de banco dBANK 
   129 												;permitidos y guarda los bancos
   130 												;encontrados desde la direccion
   131 												;TABMEMBANKS+1.
   132 												;El metodo de prueba excluye la 
   133 												;posibilidad de duplicar 
   134 												;cualquier banco de memoria
   135 												;adicional.
   136 												;La primera entrada en la tabla
   137 												;TABMEMBANKS es el valor 
   138 												;$FF, este es el codigo del
   139 												;banco numero 0 en la memoria
   140 												;primaria.
   141 												;La tabla con los bancos de
   142 												;memoria encontrados puede
   143 												;contener como maximo 65
   144 												;entradas.
   145 												;(para 1 MB de memoria 
   146 												;adicional).
   147 												;El numero de bancos 
   148 												;encontrados se devuelve en
   149 												;el registro del acumulador
   150 												;A.
   151 												;numero maximo de bancos de
   152 												;memoria
   153 = 0040											MAXBANKS = 64		
   154 20DB												MEMORIA
   155 20DB 00 00 00										    .BY $00,$00,$00
   156 20DE												MEM
   157 20DE A9 00											    LDA #$00
   158 20E0 8D DB 20										    STA MEMORIA
   159 20E3 8D DC 20										    STA MEMORIA+1
   160 20E6 8D DD 20										    STA MEMORIA+2
   161 												;byte de la memoria primaria
   162 20E9 AD FF 7F											LDA $7FFF	
   163 20EC 8D 6E 21											STA TEMP
   164 20EF A2 3F											    LDX #MAXBANKS-1
   165 20F1												S1 
   166 20F1 BD 6F 21										    LDA DBANK,X
   167 20F4 8D 01 D3										    STA PORTB
   168 20F7 AD FF 7F										    LDA $7FFF
   169 20FA 9D 00 06										    STA TABMEMBANKS,X
   170 20FD CA											    DEX
   171 20FE 10 F1											    BPL S1
   172 2100 A2 3F											    LDX #MAXBANKS-1
   173 2102												S2 
   174 2102 BD 6F 21										    LDA DBANK,X
   175 2105 8D 01 D3										    STA PORTB
   176 2108 8D FF 7F										    STA $7FFF
   177 210B CA											    DEX
   178 210C 10 F4											    BPL S2
   179 												;volvemos a la memoria basica,
   180 												;aqui debajo de $7FFF
   181 												;escribimos el valor $FF
   182 210E A9 FF												LDA #$FF
   183 2110 8D 01 D3											STA PORTB
   184 2113 8D FF 7F											STA $7FFF
   185 2116 8D 00 06											STA TABMEMBANKS ; primera
   186 												;entrada en TABMEMBANKS = $FF
   187 												;comprobamos la presencia de
   188 												;bancos de memoria adicionales,
   189 												;guardamos los bancos detectados
   190 												;desde la direccion 
   191 												;TABMEMBANKS+1 el registro
   192 												;Y cuenta los bancos de memoria
   193 												;encontrados
   194 2119 A0 00												LDY #0
   195 211B A2 3F											    LDX #MAXBANKS-1
   196 211D												LOP	
   197 211D BD 6F 21										    LDA DBANK,X
   198 2120 8D 01 D3										    STA PORTB
   199 2123 CD FF 7F										    CMP $7FFF
   200 2126 D0 07											    BNE SKP
   201 2128 99 01 06											STA TABMEMBANKS+1,Y
   202 212B C8											    INY
   203 212C 8C D4 20										    STY BANKOS
   204 212F												SKP
   205 212F CA											    DEX
   206 2130 10 EB											    BPL LOP
   207 2132 A2 3F											    LDX #MAXBANKS-1
   208 2134												R3 
   209 2134 BD 6F 21										    LDA DBANK,X
   210 2137 8D 01 D3										    STA PORTB
   211 213A BD 00 06										    LDA TABMEMBANKS,X
   212 213D 8D FF 7F										    STA $7FFF
   213 2140 CA											    DEX
   214 2141 10 F1											    BPL R3
   215 												;Terminamos restaurando la 
   216 												;memoria primaria.
   217 2143 A9 FF											    LDA #$FF
   218 2145 8D 01 D3										    STA PORTB
   219 												;Restauramos el contenido 
   220 2148 A9 00												LDA #0		
   221 												;antiguo de la celda de memoria
   222 												;desde la direccion $7FFF en la
   223 												;memoria primaria.
   224 214A 8D FF 7F											STA $7FFF
   225 												;en regla el numero de bancos 
   226 												;de memoria adicionales
   227 												;encontrados
   228 214D 98												TYA		
   229 214E AE D4 20										    LDX BANKOS
   230 2151 CA											    DEX
   231 2152												CALMEM
   232 2152 AD DB 20										    LDA MEMORIA
   233 2155 69 00												ADC #$00
   234 2157 8D DB 20											STA MEMORIA
   235 215A AD DC 20											LDA MEMORIA+1
   236 215D 69 40												ADC #$40
   237 215F 8D DC 20											STA MEMORIA+1
   238 2162 AD DD 20											LDA MEMORIA+2
   239 2165 69 00												ADC #$00
   240 2167 8D DD 20											STA MEMORIA+2
   241 216A CA												DEX
   242 216B 10 E5											    BPL CALMEM
   243 216D 60											    RTS
   244 												;La tabla DBANK contiene codigos
   245 												;permitidos para los bancos
   246 												;habilitados para PORTB
   247 216E												TEMP
   248 216E 00											    .BY $00
   249 216F												DBANK
   250 216F E3 C3 A3 83 63 43 23 03										.BY $E3,$C3,$A3,$83,$63,$43,$23,$03
   251 2177 E7 C7 A7 87 67 47 27 07									    .BY $E7,$C7,$A7,$87,$67,$47,$27,$07
   252 217F EB CB AB 8B 6B 4B 2B 0B									    .BY $EB,$CB,$AB,$8B,$6B,$4B,$2B,$0B
   253 2187 EF CF AF 8F 6F 4F 2F 0F									    .BY $EF,$CF,$AF,$8F,$6F,$4F,$2F,$0F
   254 218F ED CD AD 8D 6D 4D 2D 0D									    .BY $ED,$CD,$AD,$8D,$6D,$4D,$2D,$0D
   255 2197 E9 C9 A9 89 69 49 29 09									    .BY $E9,$C9,$A9,$89,$69,$49,$29,$09
   256 219F E5 C5 A5 85 65 45 25 05									    .BY $E5,$C5,$A5,$85,$65,$45,$25,$05
   257 21A7 E1 C1 A1 81 61 41 21 01									    .BY $E1,$C1,$A1,$81,$61,$41,$21,$01
