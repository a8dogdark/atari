   288 												; Convert an 16 bit binary value into a 24bit BCD value
   289 21DF												BIN2BCD
   290 21DF 20 BE 21											JSR LIMPIORES
   291 21E2 A9 00												LDA #0		  ;Clear the result area
   292 21E4 8D B7 21											STA RESBCD+0
   293 21E7 8D B8 21											STA RESBCD+1
   294 21EA 8D B9 21											STA RESBCD+2
   295 21ED 8D BA 21											STA RESBCD+3
   296 21F0 A2 18												LDX #24		 ;Setup the bit counter
   297 21F2 F8												SED			 ;Enter decimal mode
   298 21F3												LOOPHEX
   299 21F3 0E BB 21											ASL VAL+0	   ;Shift a bit out of the binary
   300 21F6 2E BC 21											ROL VAL+1
   301 21F9 2E BD 21											ROL VAL+2	   ;... value
   302 21FC AD B7 21											LDA RESBCD+0	   ;And add it into the result, doubling
   303 21FF 6D B7 21											ADC RESBCD+0	   ;... it at the same time
   304 2202 8D B7 21											STA RESBCD+0
   305 2205 AD B8 21											LDA RESBCD+1
   306 2208 6D B8 21											ADC RESBCD+1
   307 220B 8D B8 21											STA RESBCD+1
