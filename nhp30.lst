   290 												; Convert an 16 bit binary value into a 24bit BCD value
   291 2635												BIN2BCD
   292 2635 20 14 26											JSR LIMPIORES
   293 2638 A9 00												LDA #0		  ;Clear the result area
   294 263A 8D 0D 26											STA RESBCD+0
   295 263D 8D 0E 26											STA RESBCD+1
   296 2640 8D 0F 26											STA RESBCD+2
   297 2643 8D 10 26											STA RESBCD+3
   298 2646 A2 18												LDX #24		 ;Setup the bit counter
   299 2648 F8												SED			 ;Enter decimal mode
   300 2649												LOOPHEX
   301 2649 0E 11 26											ASL VAL+0	   ;Shift a bit out of the binary
   302 264C 2E 12 26											ROL VAL+1
   303 264F 2E 13 26											ROL VAL+2	   ;... value
   304 2652 AD 0D 26											LDA RESBCD+0	   ;And add it into the result, doubling
   305 2655 6D 0D 26											ADC RESBCD+0	   ;... it at the same time
   306 2658 8D 0D 26											STA RESBCD+0
   307 265B AD 0E 26											LDA RESBCD+1
   308 265E 6D 0E 26											ADC RESBCD+1
   309 2661 8D 0E 26											STA RESBCD+1
   310 2664 AD 0F 26											LDA RESBCD+2
   311 2667 6D 0F 26											ADC RESBCD+2
   312 266A 8D 0F 26											STA RESBCD+2
   313 266D AD 10 26											LDA RESBCD+3
   314 2670 6D 10 26											ADC RESBCD+3
   315 2673 8D 10 26											STA RESBCD+3
   316 2676 CA												DEX			 ;More bits to process?
   317 2677 D0 D0												BNE LOOPHEX
   318 2679 D8												CLD			 ;Leave decimal mode
   319 													;BRK
   320 267A												BCD2ATASCII
   321 267A A2 04												LDX #4
   322 267C A0 00												LDY #0
   323 267E												LOOP2
   324 267E BD 0C 26											LDA RESBCD-1,X
   325 2681 4A												LSR
   326 2682 4A												LSR
   327 2683 4A												LSR
   328 2684 4A												LSR
   329 2685 09 10												ORA #$10
   330 2687 99 05 26											STA RESATASCII,Y
   331 268A BD 0C 26											LDA RESBCD-1,X
   332 268D 29 0F												AND #$0F
   333 268F 09 10												ORA #$10
   334 2691 99 06 26											STA RESATASCII+1,Y
   335 2694 C8												INY
   336 2695 C8												INY
   337 2696 CA												DEX
   338 2697 D0 E5												BNE LOOP2
   339 2699 60												RTS
