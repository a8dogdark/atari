   126 												;Deteccion de memoria adicional
   127 												;El programa verifica la 
   128 												;presencia de una extension
   129 												;de memoria basandose en los 
   130 												;codigos de banco dBANK 
   131 												;permitidos y guarda los bancos
   132 												;encontrados desde la direccion
   133 												;TABMEMBANKS+1.
   134 												;El metodo de prueba excluye la 
   135 												;posibilidad de duplicar 
   136 												;cualquier banco de memoria
   137 												;adicional.
   138 												;La primera entrada en la tabla
   139 												;TABMEMBANKS es el valor 
   140 												;$FF, este es el codigo del
   141 												;banco numero 0 en la memoria
   142 												;primaria.
   143 												;La tabla con los bancos de
   144 												;memoria encontrados puede
   145 												;contener como maximo 65
   146 												;entradas.
   147 												;(para 1 MB de memoria 
   148 												;adicional).
   149 												;El numero de bancos 
   150 												;encontrados se devuelve en
   151 												;el registro del acumulador
   152 												;A.
   153 												;numero maximo de bancos de
   154 												;memoria
   155 = 0040											MAXBANKS = 64		
   156 2531												MEMORIA
   157 2531 00 00 00										    .BY $00,$00,$00
   158 2534												MEM
   159 2534 A9 00											    LDA #$00
   160 2536 8D 31 25										    STA MEMORIA
   161 2539 8D 32 25										    STA MEMORIA+1
   162 253C 8D 33 25										    STA MEMORIA+2
   163 												;byte de la memoria primaria
   164 253F AD FF 7F											LDA $7FFF	
   165 2542 8D C4 25											STA TEMP
   166 2545 A2 3F											    LDX #MAXBANKS-1
   167 2547												S1 
   168 2547 BD C5 25										    LDA DBANK,X
   169 254A 8D 01 D3										    STA PORTB
   170 254D AD FF 7F										    LDA $7FFF
   171 2550 9D 00 06										    STA TABMEMBANKS,X
   172 2553 CA											    DEX
   173 2554 10 F1											    BPL S1
   174 2556 A2 3F											    LDX #MAXBANKS-1
   175 2558												S2 
   176 2558 BD C5 25										    LDA DBANK,X
   177 255B 8D 01 D3										    STA PORTB
   178 255E 8D FF 7F										    STA $7FFF
   179 2561 CA											    DEX
   180 2562 10 F4											    BPL S2
   181 												;volvemos a la memoria basica,
   182 												;aqui debajo de $7FFF
   183 												;escribimos el valor $FF
   184 2564 A9 FF												LDA #$FF
   185 2566 8D 01 D3											STA PORTB
   186 2569 8D FF 7F											STA $7FFF
   187 256C 8D 00 06											STA TABMEMBANKS ; primera
   188 												;entrada en TABMEMBANKS = $FF
   189 												;comprobamos la presencia de
   190 												;bancos de memoria adicionales,
   191 												;guardamos los bancos detectados
   192 												;desde la direccion 
   193 												;TABMEMBANKS+1 el registro
   194 												;Y cuenta los bancos de memoria
   195 												;encontrados
   196 256F A0 00												LDY #0
   197 2571 A2 3F											    LDX #MAXBANKS-1
   198 2573												LOP	
   199 2573 BD C5 25										    LDA DBANK,X
   200 2576 8D 01 D3										    STA PORTB
   201 2579 CD FF 7F										    CMP $7FFF
   202 257C D0 07											    BNE SKP
   203 257E 99 01 06											STA TABMEMBANKS+1,Y
   204 2581 C8											    INY
   205 2582 8C 2A 25										    STY BANKOS
   206 2585												SKP
   207 2585 CA											    DEX
   208 2586 10 EB											    BPL LOP
   209 2588 A2 3F											    LDX #MAXBANKS-1
   210 258A												R3 
   211 258A BD C5 25										    LDA DBANK,X
   212 258D 8D 01 D3										    STA PORTB
   213 2590 BD 00 06										    LDA TABMEMBANKS,X
   214 2593 8D FF 7F										    STA $7FFF
   215 2596 CA											    DEX
   216 2597 10 F1											    BPL R3
   217 												;Terminamos restaurando la 
   218 												;memoria primaria.
   219 2599 A9 FF											    LDA #$FF
   220 259B 8D 01 D3										    STA PORTB
   221 												;Restauramos el contenido 
   222 259E A9 00												LDA #0		
   223 												;antiguo de la celda de memoria
   224 												;desde la direccion $7FFF en la
   225 												;memoria primaria.
   226 25A0 8D FF 7F											STA $7FFF
   227 												;en regla el numero de bancos 
   228 												;de memoria adicionales
   229 												;encontrados
   230 25A3 98												TYA		
   231 25A4 AE 2A 25										    LDX BANKOS
   232 25A7 CA											    DEX
   233 25A8												CALMEM
   234 25A8 AD 31 25										    LDA MEMORIA
   235 25AB 69 00												ADC #$00
   236 25AD 8D 31 25											STA MEMORIA
   237 25B0 AD 32 25											LDA MEMORIA+1
   238 25B3 69 40												ADC #$40
   239 25B5 8D 32 25											STA MEMORIA+1
   240 25B8 AD 33 25											LDA MEMORIA+2
   241 25BB 69 00												ADC #$00
   242 25BD 8D 33 25											STA MEMORIA+2
   243 25C0 CA												DEX
   244 25C1 10 E5											    BPL CALMEM
   245 25C3 60											    RTS
   246 												;La tabla DBANK contiene codigos
   247 												;permitidos para los bancos
   248 												;habilitados para PORTB
   249 25C4												TEMP
   250 25C4 00											    .BY $00
   251 25C5												DBANK
   252 25C5 E3 C3 A3 83 63 43 23 03										.BY $E3,$C3,$A3,$83,$63,$43,$23,$03
   253 25CD E7 C7 A7 87 67 47 27 07									    .BY $E7,$C7,$A7,$87,$67,$47,$27,$07
   254 25D5 EB CB AB 8B 6B 4B 2B 0B									    .BY $EB,$CB,$AB,$8B,$6B,$4B,$2B,$0B
   255 25DD EF CF AF 8F 6F 4F 2F 0F									    .BY $EF,$CF,$AF,$8F,$6F,$4F,$2F,$0F
   256 25E5 ED CD AD 8D 6D 4D 2D 0D									    .BY $ED,$CD,$AD,$8D,$6D,$4D,$2D,$0D
   257 25ED E9 C9 A9 89 69 49 29 09									    .BY $E9,$C9,$A9,$89,$69,$49,$29,$09
   258 25F5 E5 C5 A5 85 65 45 25 05									    .BY $E5,$C5,$A5,$85,$65,$45,$25,$05
   259 25FD E1 C1 A1 81 61 41 21 01									    .BY $E1,$C1,$A1,$81,$61,$41,$21,$01
